# Copy this file to .env and fill your real key. Do not commit .env.
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_VISION_MODEL=gpt-4o-mini

# Optional: move command-line flags into .env
PHYSICS_AUTO_REVIEW_PROVIDER=openai
PHYSICS_AUTO_REVIEW_THRESHOLD=0.90
PHYSICS_AUTO_REVIEW_MAX_ITEMS=0
PHYSICS_FAIL_ON_REVIEW_REQUIRED=true
PHYSICS_ALLOW_REVIEW_REQUIRED=false
PHYSICS_PLACEHOLDER_UNREVIEWED=false
PHYSICS_SKIP_FINAL_ARTIFACT_GATE=false
PHYSICS_ALLOW_FINAL_ARTIFACTS=false
